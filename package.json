{
  "name": "n8n-nodes-jobber",
  "version": "0.1.0",
  "description": "n8n community node for Jobber field service management",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "jobber",
    "field-service"
  ],
  "license": "MIT",
  "author": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "tslint -p tsconfig.json -c tslint.json",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/JobberOAuth2Api.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Jobber/Jobber.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.0.0",
    "typescript": "~5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
